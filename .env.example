# Greenways optional LLM (Render Environment — do not commit real keys)

# --- Cortecs (recommended — JWT from HTMLS GWM GWB/Contl2 .txt) ---
# Docs: https://docs.cortecs.ai/api-overview/chat-completions.md
ASSISTANT_PROVIDER=cortecs
ASSISTANT_API_KEY=eyJ...paste-from-Contl2-txt
ASSISTANT_MODEL=anthropic/claude-3.5-sonnet
# Optional EU routing: pass preference via future agent payload; base URL default:
# ASSISTANT_API_BASE=https://api.cortecs.ai/v1

# --- OpenRouter fallback (sk-or-v1 key) ---
# ASSISTANT_PROVIDER=openrouter
# ASSISTANT_API_KEY=sk-or-v1-...
# ASSISTANT_MODEL=anthropic/claude-3.5-sonnet

# Optional — LLM polish on knowledge hits (launch mode). Default: finance,equipment
# GREENWAYS_AGENT_POLISH_AGENTS=finance,equipment
# Artemis pilot intents only (when equipment is in polish list):
# EQUIPMENT_AGENT_POLISH_INTENTS=deep_dive,why_equipment,insulation

OPENROUTER_HTTP_REFERER=https://energy-calc-backend.onrender.com
OPENROUTER_APP_TITLE=Greenways Agents

# Live Music Finder guide — optional overrides (defaults to ASSISTANT_* above)
# MUSIC_GUIDE_PROVIDER=cortecs
# MUSIC_GUIDE_API_KEY=eyJ...
# MUSIC_GUIDE_MODEL=anthropic/claude-3.5-sonnet

# Site energy reading — EU live grid (NL / ES / PT) on Render
# 1) Register: https://transparency.entsoe.eu/
# 2) Email transparency@entsoe.eu — subject "Restful API access", body = your registered email
# 3) After approval (~3 working days): My Account → generate security token
# ENTSOE_API_KEY=your-entsoe-security-token
# Optional — adds EU 24h carbon forecast (https://electricitymaps.com/)
# ELECTRICITY_MAPS_API_KEY=your-electricity-maps-token

# Agent voice — premium TTS (Wave 8). Falls back to browser speechSynthesis when unset.
# Option A: SkillBoss gateway (ElevenLabs via one key) — https://skillboss.co/console
# SKILLBOSS_API_KEY=sk-...
# Option B: Direct ElevenLabs — https://elevenlabs.io/
# ELEVENLABS_API_KEY=...
# AGENT_VOICE_TTS_PROVIDER=auto
# Pilot voices: data/greenways-agent-voice-config.json (Andrieus useServerTts: true)
