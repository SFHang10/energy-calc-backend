# Server Configuration
PORT=4000
NODE_ENV=development

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database Configuration
# MongoDB (Primary - Production)
# Use the SAME MONGODB_URI on Render and in local .env after any Atlas password change.
# Atlas → Database Access (DB user password) — NOT the org "Service Account" secret email.
# URL-encode special chars in password: @ → %40  $ → %24  # → %23
USE_MONGODB=true
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/energy_calculator?retryWrites=true&w=majority

# SQLite (Fallback - Development)
USE_SQLITE_FALLBACK=true
DB_PATH=./database/members.db

# Stripe Configuration (for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Wix Site Configuration
WIX_SITE_URL=https://your-wix-site.com
WIX_SITE_ID=d9c9c6b1-f79a-49a3-8183-4c5a8e24a413

# Wix Authentication - Choose ONE method:

# Method 1: Direct App Token (if available)
WIX_APP_TOKEN=your_wix_app_token_here

# Method 2: OAuth (App ID + Secret) - Recommended
# WIX_APP_ID=your_app_id_here
# WIX_APP_SECRET=your_app_secret_here
# WIX_INSTANCE_ID=your_instance_id_here

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MUSIC_INQUIRY_FROM=your-email@gmail.com
MUSIC_INQUIRY_NOTIFY_TO=bookings@youragency.com
MUSIC_INQUIRY_RATE_WINDOW_MS=600000
MUSIC_INQUIRY_RATE_MAX=5

# Optional LLM for Music Guide (falls back to heuristic matching when unset)
# MUSIC_GUIDE_PROVIDER=openai
# MUSIC_GUIDE_API_KEY=sk-...
# MUSIC_GUIDE_MODEL=gpt-4o-mini












































