{
  "updatedAt": "2026-06-17",
  "meta": {
    "title": "Greenways Guide Agent — orchestrator intents",
    "description": "Hub conductor — routes to specialist agents and returns handoff links."
  },
  "staticTips": [
    "I route your question to the best Greenways specialist — open their agent page for a deeper chat.",
    "Not sure where to start? Ask in plain language; I'll suggest Grants, Finance, Equipment, Products, Deals, or Media."
  ],
  "intents": [
    {
      "id": "overview",
      "patterns": ["overview", "who are you", "what is greenways guide", "help me", "hello", "hi"],
      "answerType": "overview"
    },
    {
      "id": "roster",
      "patterns": ["which agent", "list agents", "all agents", "specialists", "orchestra", "team", "who can help"],
      "answerType": "roster"
    },
    {
      "id": "route_grants",
      "patterns": ["grant", "scheme", "subsidy", "mia", "vamil", "funding not loan", "deadline"],
      "answerType": "route",
      "agent": "grants"
    },
    {
      "id": "route_finance",
      "patterns": ["finance", "loan", "bnpl", "payback", "roi", "energy price", "warmtefonds", "green loan"],
      "answerType": "route",
      "agent": "finance"
    },
    {
      "id": "route_upgrade_plan",
      "patterns": [
        "upgrade plan",
        "equipment upgrade plan",
        "plan my upgrade",
        "step by step upgrade",
        "how do i upgrade",
        "kitchen upgrade plan",
        "fridge upgrade plan"
      ],
      "answerType": "route",
      "agent": "equipment"
    },
    {
      "id": "route_equipment",
      "patterns": ["equipment", "deep dive", "renovation", "insulation", "marketplace", "etl_", "combi steamer"],
      "answerType": "route",
      "agent": "equipment"
    },
    {
      "id": "route_products",
      "patterns": ["find product", "water saving", "sust_", "catalog", "efficient fridge", "dishwasher", "aerator"],
      "answerType": "route",
